# --- Publicación automática de testimonios (solo producción/Vercel) ---

# Token de GitHub (fine-grained) con permiso "Contents: Read and write"
# SOLO sobre el repo del sitio. Crear en:
# https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Repo y rama donde vive el sitio (Vercel redespliega con cada commit)
GITHUB_REPO=joshuascott0521/chaila
GITHUB_BRANCH=main

# Opcional: código de invitación. Si lo defines, el link a compartir es
# https://tu-dominio.com/testimonio?c=ESTE_CODIGO — sin él no se puede publicar.
TESTIMONIOS_CODE=
